# ============================================
#  BloodConnect - Environment Configuration
# ============================================
#  Copy this file to .env and fill your details
#  NEVER share your real .env file!
# ============================================

# Server Port
PORT=3000

# MongoDB Connection
# Option 1: Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/bloodDonationPortal

# Option 2: MongoDB Atlas (Cloud - FREE)
# 1. Go to: https://www.mongodb.com/cloud/atlas
# 2. Create FREE account & cluster
# 3. Get connection string and replace below
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/bloodDonationPortal?retryWrites=true&w=majority

# JWT Secret Key (Change this!)
# Generate random string or use any long text
JWT_SECRET=your_jwt_secret_key_change_this_to_random_text

# Session Secret Key (Change this!)
SESSION_SECRET=your_session_secret_change_this_to_random_text

# Email Configuration (Optional - for notifications)
# Using Gmail? Follow these steps:
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Select "Mail" > "Windows Computer" > Generate
# 4. Copy 16-digit code (with spaces) and paste below
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_digit_app_password_here

# Node Environment
NODE_ENV=development

# Base URL
BASE_URL=http://localhost:3000

# Admin Secret Code (For Admin Registration)
# Use this code during registration to become admin
ADMIN_SECRET_CODE=admin123
