<%- include("../partials/header") %>

<!-- Hero Section -->
<div class="bg-danger text-white py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-4 fw-bold">Donate Blood, Save Lives</h1>
                <p class="lead">Every drop of blood can save someone's life. Join our community of heroes today.</p>
                <a href="/auth/register" class="btn btn-light btn-lg text-danger fw-bold mt-3">Become a Donor</a>
                <a href="/emergency/create" class="btn btn-outline-light btn-lg mt-3 ms-2">Emergency Request</a>
            </div>
            <div class="col-md-6 text-center">
                <i class="fas fa-heartbeat fa-8x text-white opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<!-- Stats Section -->
<div class="container py-5">
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <i class="fas fa-users fa-3x text-danger mb-3"></i>
                    <h3 class="fw-bold"><%= stats.totalDonors %></h3>
                    <p class="text-muted">Registered Donors</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <i class="fas fa-clock fa-3x text-danger mb-3"></i>
                    <h3 class="fw-bold"><%= stats.activeRequests %></h3>
                    <p class="text-muted">Active Requests</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <i class="fas fa-heart fa-3x text-danger mb-3"></i>
                    <h3 class="fw-bold"><%= stats.livesSaved %></h3>
                    <p class="text-muted">Lives Saved</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-5">Why Choose BloodConnect?</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card h-100 text-center border-0 shadow-sm">
                    <div class="card-body p-4">
                        <i class="fas fa-search fa-3x text-danger mb-3"></i>
                        <h4>Quick Search</h4>
                        <p class="text-muted">Find blood donors near you instantly.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100 text-center border-0 shadow-sm">
                    <div class="card-body p-4">
                        <i class="fas fa-shield-alt fa-3x text-danger mb-3"></i>
                        <h4>Verified Donors</h4>
                        <p class="text-muted">All donors are properly verified.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100 text-center border-0 shadow-sm">
                    <div class="card-body p-4">
                        <i class="fas fa-bolt fa-3x text-danger mb-3"></i>
                        <h4>Emergency Response</h4>
                        <p class="text-muted">Instant alerts to nearby donors.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Blood Groups - CLICKABLE with WHITE TEXT -->
<div class="bg-danger text-white py-5">
    <div class="container text-center">
        <h2 class="mb-4">Find Donors by Blood Group</h2>
        <p class="mb-4">Click on any blood group to find available donors</p>
        <div class="row">
            <div class="col-6 col-md-3 mb-3">
                <a href="/donor/search?bloodGroup=A%2B" class="text-decoration-none text-white">
                    <div class="bg-white bg-opacity-25 rounded p-4 blood-group-card">
                        <h3 class="mb-0 fw-bold">A+</h3>
                        <small>Click to search</small>
                    </div>
                </a>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <a href="/donor/search?bloodGroup=B%2B" class="text-decoration-none text-white">
                    <div class="bg-white bg-opacity-25 rounded p-4 blood-group-card">
                        <h3 class="mb-0 fw-bold">B+</h3>
                        <small>Click to search</small>
                    </div>
                </a>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <a href="/donor/search?bloodGroup=O%2B" class="text-decoration-none text-white">
                    <div class="bg-white bg-opacity-25 rounded p-4 blood-group-card">
                        <h3 class="mb-0 fw-bold">O+</h3>
                        <small>Click to search</small>
                    </div>
                </a>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <a href="/donor/search?bloodGroup=AB%2B" class="text-decoration-none text-white">
                    <div class="bg-white bg-opacity-25 rounded p-4 blood-group-card">
                        <h3 class="mb-0 fw-bold">AB+</h3>
                        <small>Click to search</small>
                    </div>
                </a>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <a href="/donor/search?bloodGroup=A-" class="text-decoration-none text-white">
                    <div class="bg-white bg-opacity-25 rounded p-4 blood-group-card">
                        <h3 class="mb-0 fw-bold">A-</h3>
                        <small>Click to search</small>
                    </div>
                </a>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <a href="/donor/search?bloodGroup=B-" class="text-decoration-none text-white">
                    <div class="bg-white bg-opacity-25 rounded p-4 blood-group-card">
                        <h3 class="mb-0 fw-bold">B-</h3>
                        <small>Click to search</small>
                    </div>
                </a>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <a href="/donor/search?bloodGroup=O-" class="text-decoration-none text-white">
                    <div class="bg-white bg-opacity-25 rounded p-4 blood-group-card">
                        <h3 class="mb-0 fw-bold">O-</h3>
                        <small>Click to search</small>
                    </div>
                </a>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <a href="/donor/search?bloodGroup=AB-" class="text-decoration-none text-white">
                    <div class="bg-white bg-opacity-25 rounded p-4 blood-group-card">
                        <h3 class="mb-0 fw-bold">AB-</h3>
                        <small>Click to search</small>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Call to Action -->
<div class="container py-5 text-center">
    <h2 class="mb-4">Ready to Save Lives?</h2>
    <p class="lead mb-4">Join thousands of donors making a difference every day.</p>
    <a href="/auth/register" class="btn btn-danger btn-lg px-5">Register as a Donor Now</a>
</div>

<style>
.blood-group-card {
    transition: all 0.3s ease;
    cursor: pointer;
    border: 2px solid transparent;
}
.blood-group-card:hover {
    background-color: rgba(255, 255, 255, 0.4) !important;
    transform: scale(1.1);
    border-color: white;
}
</style>

<%- include("../partials/footer") %>
