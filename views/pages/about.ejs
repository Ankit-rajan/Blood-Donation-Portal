<%- include("../partials/header") %>

<!-- About Header -->
<div class="bg-danger text-white py-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">About BloodConnect</h1>
        <p class="lead">Connecting Blood Donors With Those In Need Since 2024</p>
    </div>
</div>

<!-- Mission & Vision -->
<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-lg-6 mb-4">
            <h2 class="text-danger mb-4">Our Mission</h2>
            <p class="lead">To ensure that no one dies due to lack of blood by creating a seamless connection between blood donors and recipients across India.</p>
            <p>BloodConnect is a community-driven platform that bridges the critical gap between voluntary blood donors and patients in urgent need. We leverage technology to make blood donation more accessible, efficient, and life-saving.</p>
            <p>Every year, India faces a shortage of millions of units of blood. Our mission is to create a reliable network of verified donors who can respond quickly to emergency requests and help save precious lives.</p>
            
            <div class="row mt-4">
                <div class="col-6">
                    <h4 class="text-danger">Our Vision</h4>
                    <p>A world where no patient suffers due to unavailability of blood.</p>
                </div>
                <div class="col-6">
                    <h4 class="text-danger">Our Goal</h4>
                    <p>To register 1 million active blood donors across India by 2026.</p>
                </div>
            </div>
        </div>
        <div class="col-lg-6 text-center">
            <img src="/images/blood-donation.svg" alt="Blood Donation" class="img-fluid" style="max-height: 400px;" onerror="this.style.display='none'">
            <i class="fas fa-hand-holding-heart fa-10x text-danger opacity-75"></i>
        </div>
    </div>
</div>

<!-- Impact Stats -->
<div class="bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-5">Our Impact</h2>
        <div class="row text-center">
            <div class="col-md-3 col-6 mb-4">
                <div class="bg-white p-4 rounded shadow-sm">
                    <i class="fas fa-users fa-3x text-danger mb-3"></i>
                    <h3 class="fw-bold text-danger">100+</h3>
                    <p class="text-muted mb-0">Registered Donors</p>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4">
                <div class="bg-white p-4 rounded shadow-sm">
                    <i class="fas fa-hospital fa-3x text-danger mb-3"></i>
                    <h3 class="fw-bold text-danger">50+</h3>
                    <p class="text-muted mb-0">Partner Hospitals</p>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4">
                <div class="bg-white p-4 rounded shadow-sm">
                    <i class="fas fa-heart fa-3x text-danger mb-3"></i>
                    <h3 class="fw-bold text-danger">500+</h3>
                    <p class="text-muted mb-0">Lives Impacted</p>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4">
                <div class="bg-white p-4 rounded shadow-sm">
                    <i class="fas fa-city fa-3x text-danger mb-3"></i>
                    <h3 class="fw-bold text-danger">30+</h3>
                    <p class="text-muted mb-0">Cities Covered</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- What We Do -->
<div class="container py-5">
    <h2 class="text-center mb-5">What We Do</h2>
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="bg-danger bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="fas fa-database fa-2x text-danger"></i>
                    </div>
                    <h4>Donor Database</h4>
                    <p class="text-muted">Maintain a comprehensive, verified database of blood donors with detailed profiles including blood group, location, and availability status.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="bg-danger bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="fas fa-bell fa-2x text-danger"></i>
                    </div>
                    <h4>Emergency Alerts</h4>
                    <p class="text-muted">Send instant email notifications to matching donors in the vicinity when emergency blood requests are raised, ensuring quick response times.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="bg-danger bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="fas fa-search-location fa-2x text-danger"></i>
                    </div>
                    <h4>Smart Search</h4>
                    <p class="text-muted">Advanced search and filter system to find the right donors based on blood group, location, pincode, and availability in real-time.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- How It Works -->
<div class="bg-danger text-white py-5">
    <div class="container">
        <h2 class="text-center mb-5">How It Works</h2>
        <div class="row text-center">
            <div class="col-md-3 col-6 mb-4">
                <div class="mb-3">
                    <span class="badge bg-white text-danger rounded-circle p-3" style="font-size: 1.5rem; width: 50px; height: 50px;">1</span>
                </div>
                <h5>Register</h5>
                <p class="small opacity-75">Create your donor profile with basic information and blood group</p>
            </div>
            <div class="col-md-3 col-6 mb-4">
                <div class="mb-3">
                    <span class="badge bg-white text-danger rounded-circle p-3" style="font-size: 1.5rem; width: 50px; height: 50px;">2</span>
                </div>
                <h5>Verify</h5>
                <p class="small opacity-75">Upload your ID and medical documents for verification</p>
            </div>
            <div class="col-md-3 col-6 mb-4">
                <div class="mb-3">
                    <span class="badge bg-white text-danger rounded-circle p-3" style="font-size: 1.5rem; width: 50px; height: 50px;">3</span>
                </div>
                <h5>Get Alerts</h5>
                <p class="small opacity-75">Receive notifications when someone needs your blood type nearby</p>
            </div>
            <div class="col-md-3 col-6 mb-4">
                <div class="mb-3">
                    <span class="badge bg-white text-danger rounded-circle p-3" style="font-size: 1.5rem; width: 50px; height: 50px;">4</span>
                </div>
                <h5>Donate & Save</h5>
                <p class="small opacity-75">Donate blood and become a real-life hero for someone in need</p>
            </div>
        </div>
    </div>
</div>

<!-- Why Donate Blood -->
<div class="container py-5">
    <h2 class="text-center mb-5">Why Donate Blood?</h2>
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="d-flex">
                <div class="flex-shrink-0">
                    <i class="fas fa-check-circle fa-2x text-success me-3 mt-1"></i>
                </div>
                <div>
                    <h5>Safe & Simple Process</h5>
                    <p class="text-muted">Blood donation is completely safe. All equipment is sterile, used only once, and the process takes only 30-45 minutes.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="d-flex">
                <div class="flex-shrink-0">
                    <i class="fas fa-check-circle fa-2x text-success me-3 mt-1"></i>
                </div>
                <div>
                    <h5>Health Benefits</h5>
                    <p class="text-muted">Regular blood donation helps maintain healthy iron levels, reduces heart disease risk, and stimulates blood cell production.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="d-flex">
                <div class="flex-shrink-0">
                    <i class="fas fa-check-circle fa-2x text-success me-3 mt-1"></i>
                </div>
                <div>
                    <h5>Save Up To 3 Lives</h5>
                    <p class="text-muted">One unit of blood can be separated into components (RBCs, plasma, platelets) and can save up to three different lives.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="d-flex">
                <div class="flex-shrink-0">
                    <i class="fas fa-check-circle fa-2x text-success me-3 mt-1"></i>
                </div>
                <div>
                    <h5>Free Health Checkup</h5>
                    <p class="text-muted">Before donation, you get a mini health screening including blood pressure, hemoglobin, and temperature check - all free.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Who Can Donate -->
<div class="bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-5">Who Can Donate Blood?</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-user-check fa-3x text-success mb-3"></i>
                        <h5>Eligibility Criteria</h5>
                        <ul class="list-unstyled text-start text-muted">
                            <li class="mb-2">✅ Age: 18-65 years</li>
                            <li class="mb-2">✅ Weight: Above 45 kg</li>
                            <li class="mb-2">✅ Hemoglobin: Minimum 12.5 g/dL</li>
                            <li class="mb-2">✅ Good general health</li>
                            <li class="mb-2">✅ No active infections</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-clock fa-3x text-info mb-3"></i>
                        <h5>Donation Frequency</h5>
                        <ul class="list-unstyled text-start text-muted">
                            <li class="mb-2">👨 Males: Every 3 months</li>
                            <li class="mb-2">👩 Females: Every 4 months</li>
                            <li class="mb-2">🩸 Whole Blood: 350-450 ml</li>
                            <li class="mb-2">⏱️ Duration: 30-45 minutes</li>
                            <li class="mb-2">💪 Recovery: 24-48 hours</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-ban fa-3x text-danger mb-3"></i>
                        <h5>Temporary Deferrals</h5>
                        <ul class="list-unstyled text-start text-muted">
                            <li class="mb-2">❌ Recent tattoo/piercing (6 months)</li>
                            <li class="mb-2">❌ Recent major surgery (6 months)</li>
                            <li class="mb-2">❌ Pregnancy/Lactation (12 months)</li>
                            <li class="mb-2">❌ Active cold/flu</li>
                            <li class="mb-2">❌ Recent vaccination (varies)</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Blood Compatibility -->
<div class="container py-5">
    <h2 class="text-center mb-4">Blood Group Compatibility</h2>
    <p class="text-center text-muted mb-5">Understanding blood group compatibility helps in emergencies</p>
    
    <div class="table-responsive">
        <table class="table table-bordered text-center">
            <thead class="bg-danger text-white">
                <tr>
                    <th>Blood Group</th>
                    <th>Can Donate To</th>
                    <th>Can Receive From</th>
                    <th>Universal</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-bold text-danger">O-</td>
                    <td>All groups</td>
                    <td>O- only</td>
                    <td><span class="badge bg-success">Universal Donor</span></td>
                </tr>
                <tr>
                    <td class="fw-bold text-danger">O+</td>
                    <td>O+, A+, B+, AB+</td>
                    <td>O+, O-</td>
                    <td>-</td>
                </tr>
                <tr>
                    <td class="fw-bold text-danger">A-</td>
                    <td>A-, A+, AB-, AB+</td>
                    <td>A-, O-</td>
                    <td>-</td>
                </tr>
                <tr>
                    <td class="fw-bold text-danger">A+</td>
                    <td>A+, AB+</td>
                    <td>A+, A-, O+, O-</td>
                    <td>-</td>
                </tr>
                <tr>
                    <td class="fw-bold text-danger">B-</td>
                    <td>B-, B+, AB-, AB+</td>
                    <td>B-, O-</td>
                    <td>-</td>
                </tr>
                <tr>
                    <td class="fw-bold text-danger">B+</td>
                    <td>B+, AB+</td>
                    <td>B+, B-, O+, O-</td>
                    <td>-</td>
                </tr>
                <tr>
                    <td class="fw-bold text-danger">AB-</td>
                    <td>AB-, AB+</td>
                    <td>All negative groups</td>
                    <td>-</td>
                </tr>
                <tr>
                    <td class="fw-bold text-danger">AB+</td>
                    <td>AB+ only</td>
                    <td>All groups</td>
                    <td><span class="badge bg-info">Universal Recipient</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

