<%- include("../partials/header") %>

<!-- About Header -->
<div class="bg-danger text-white py-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">About BloodConnect</h1>
        <p class="lead">Connecting blood donors with those in need since 2024</p>
    </div>
</div>

<!-- Mission Section -->
<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-lg-6 mb-4" data-aos="fade-right">
            <h2>Our Mission</h2>
            <p class="lead">To ensure that no one dies due to lack of blood by creating a seamless connection between blood donors and recipients.</p>
            <p>BloodConnect is a community-driven platform that bridges the gap between blood donors and patients in need. We leverage technology to make blood donation more accessible, efficient, and life-saving.</p>
            <p>Every year, millions of units of blood are needed worldwide. Our mission is to create a reliable network of verified donors who can respond quickly to emergency requests.</p>
        </div>
        <div class="col-lg-6 text-center" data-aos="fade-left">
            <i class="fas fa-hand-holding-heart fa-10x text-danger"></i>
        </div>
    </div>
</div>

<!-- What We Do -->
<div class="bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-5">What We Do</h2>
        <div class="row">
            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-database fa-3x text-danger mb-3"></i>
                        <h4>Donor Database</h4>
                        <p>Maintain a comprehensive database of verified blood donors with detailed information.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-bell fa-3x text-danger mb-3"></i>
                        <h4>Emergency Alerts</h4>
                        <p>Send instant notifications to matching donors when emergency requests arise.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="300">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-search-location fa-3x text-danger mb-3"></i>
                        <h4>Location-Based Search</h4>
                        <p>Find donors near you quickly using our advanced search and filter system.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Impact Stats -->
<div class="container py-5">
    <h2 class="text-center mb-5">Our Impact</h2>
    <div class="row text-center">
        <div class="col-md-3 mb-4" data-aos="fade-up">
            <div class="p-4">
                <i class="fas fa-users fa-3x text-danger mb-3"></i>
                <h3 class="fw-bold">500+</h3>
                <p>Registered Donors</p>
            </div>
        </div>
        <div class="col-md-3 mb-4" data-aos="fade-up" data-aos-delay="100">
            <div class="p-4">
                <i class="fas fa-hospital fa-3x text-danger mb-3"></i>
                <h3 class="fw-bold">100+</h3>
                <p>Hospitals Connected</p>
            </div>
        </div>
        <div class="col-md-3 mb-4" data-aos="fade-up" data-aos-delay="200">
            <div class="p-4">
                <i class="fas fa-heart fa-3x text-danger mb-3"></i>
                <h3 class="fw-bold">1500+</h3>
                <p>Lives Saved</p>
            </div>
        </div>
        <div class="col-md-3 mb-4" data-aos="fade-up" data-aos-delay="300">
            <div class="p-4">
                <i class="fas fa-city fa-3x text-danger mb-3"></i>
                <h3 class="fw-bold">50+</h3>
                <p>Cities Covered</p>
            </div>
        </div>
    </div>
</div>

<!-- Team Section -->
<div class="bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-5">Why Donate Blood?</h2>
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5><i class="fas fa-check-circle text-success me-2"></i>Safe Process</h5>
                        <p>Blood donation is completely safe. All equipment is sterile and used only once.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5><i class="fas fa-check-circle text-success me-2"></i>Quick & Easy</h5>
                        <p>The donation process takes only 30-45 minutes and you can resume normal activities.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5><i class="fas fa-check-circle text-success me-2"></i>Health Benefits</h5>
                        <p>Regular blood donation can help maintain healthy iron levels and reduce heart disease risk.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5><i class="fas fa-check-circle text-success me-2"></i>Save 3 Lives</h5>
                        <p>One unit of blood can save up to three lives. Your donation makes a real difference.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CTA -->
<div class="container py-5 text-center">
    <h2>Join Our Mission Today</h2>
    <p class="lead mb-4">Become a part of the largest blood donor community. Together, we can save lives.</p>
    <a href="/auth/register" class="btn btn-danger btn-lg">Register Now</a>
</div>

<%- include("../partials/footer") %>
