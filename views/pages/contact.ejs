<%- include("../partials/header") %>

<!-- Contact Header -->
<div class="bg-danger text-white py-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">Contact Us</h1>
        <p class="lead">We're here to help and answer any questions</p>
    </div>
</div>

<div class="container py-5">
    <div class="row">
        <!-- Contact Form -->
        <div class="col-lg-7 mb-4">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h3 class="mb-4">Send us a Message</h3>
                    <form action="/contact" method="POST">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Your Name *</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                                    <input type="text" class="form-control" name="name" required placeholder="John Doe">
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email Address *</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                    <input type="email" class="form-control" name="email" required placeholder="john@example.com">
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Subject *</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-heading"></i></span>
                                <input type="text" class="form-control" name="subject" required placeholder="How can we help?">
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Message *</label>
                            <textarea class="form-control" name="message" rows="5" required placeholder="Write your message here..."></textarea>
                        </div>
                        
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="fas fa-paper-plane me-2"></i>Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
        
        <!-- Contact Info -->
        <div class="col-lg-5">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h4 class="mb-4">Get in Touch</h4>
                    
                    <div class="d-flex mb-3">
                        <div class="flex-shrink-0">
                            <i class="fas fa-map-marker-alt fa-2x text-danger me-3"></i>
                        </div>
                        <div>
                            <h6>Address</h6>
                            <p class="text-muted">123 Health Street, Medical District, Mumbai - 400001</p>
                        </div>
                    </div>
                    
                    <div class="d-flex mb-3">
                        <div class="flex-shrink-0">
                            <i class="fas fa-phone fa-2x text-danger me-3"></i>
                        </div>
                        <div>
                            <h6>Phone</h6>
                            <p class="text-muted">+91 12345 67890</p>
                            <p class="text-muted">+91 98765 43210</p>
                        </div>
                    </div>
                    
                    <div class="d-flex mb-3">
                        <div class="flex-shrink-0">
                            <i class="fas fa-envelope fa-2x text-danger me-3"></i>
                        </div>
                        <div>
                            <h6>Email</h6>
                            <p class="text-muted">info@bloodconnect.com</p>
                            <p class="text-muted">support@bloodconnect.com</p>
                        </div>
                    </div>
                    
                    <div class="d-flex">
                        <div class="flex-shrink-0">
                            <i class="fas fa-clock fa-2x text-danger me-3"></i>
                        </div>
                        <div>
                            <h6>Working Hours</h6>
                            <p class="text-muted">24/7 Emergency Support</p>
                            <p class="text-muted">Office: Mon-Sat, 9AM-6PM</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Social Media -->
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="mb-3">Follow Us</h5>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="#" class="btn btn-outline-danger"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="btn btn-outline-danger"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="btn btn-outline-danger"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="btn btn-outline-danger"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" class="btn btn-outline-danger"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Map Section -->
<div class="container-fluid p-0">
    <div class="bg-light py-5 text-center">
        <div class="container">
            <h3 class="mb-3">Our Location</h3>
            <p class="text-muted">Visit our office or reach out to us online</p>
            <i class="fas fa-map-marked-alt fa-5x text-danger"></i>
        </div>
    </div>
</div>

<!-- FAQ Quick Links -->
<div class="container py-5">
    <div class="text-center">
        <h3>Frequently Asked Questions</h3>
        <p class="mb-4">Have questions? Check our FAQ or contact us directly.</p>
        <div class="row">
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h6>Who can donate blood?</h6>
                        <small class="text-muted">Anyone healthy, aged 18-65, weighing at least 45kg can donate.</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h6>Is blood donation safe?</h6>
                        <small class="text-muted">Yes, completely safe with sterile, disposable equipment.</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h6>How often can I donate?</h6>
                        <small class="text-muted">Every 3 months for males, every 4 months for females.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("../partials/footer") %>
