<%- include("../partials/header") %>

<div class="container py-4">
    <h2 class="mb-4">Find Blood Donors</h2>
    
    <!-- Search Form -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form action="/donor/search" method="GET">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Blood Group</label>
                        <select class="form-select" name="bloodGroup">
                            <option value="">All Groups</option>
                            <% bloodGroups.forEach(group => { %>
                                <option value="<%= group %>" <%= query.bloodGroup === group ? "selected" : "" %>>
                                    <%= group %>
                                </option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">State</label>
                        <input type="text" class="form-control" name="state" value="<%= query.state || "" %>" 
                               placeholder="Enter state">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">City</label>
                        <input type="text" class="form-control" name="city" value="<%= query.city || "" %>" 
                               placeholder="Enter city">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Pincode</label>
                        <input type="text" class="form-control" name="pincode" value="<%= query.pincode || "" %>" 
                               placeholder="Enter pincode">
                    </div>
                </div>
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-search me-2"></i>Search Donors
                </button>
                <a href="/donor/search" class="btn btn-outline-secondary">Clear</a>
            </form>
        </div>
    </div>

    <!-- Results -->
    <div class="row">
        <% if (donors && donors.length > 0) { %>
            <% donors.forEach(donor => { %>
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <img src="/uploads/profiles/<%= donor.profileImage || "default-profile.png" %>" 
                                 class="rounded-circle mb-3" width="80" height="80" style="object-fit: cover;">
                            <h5 class="card-title"><%= donor.name %></h5>
                            <span class="badge bg-danger mb-2 p-2"><%= donor.bloodGroup %></span>
                            <p class="mb-1"><i class="fas fa-map-marker-alt text-danger me-1"></i><%= donor.city || "N/A" %>, <%= donor.state || "" %></p>
                            
                            <% if (donor.availability) { %>
                                <span class="badge bg-success mb-2">Available</span>
                            <% } else { %>
                                <span class="badge bg-secondary mb-2">Unavailable</span>
                            <% } %>
                            
                            <a href="/donor/profile/<%= donor._id %>" class="btn btn-outline-danger btn-sm w-100">
                                View Profile
                            </a>
                        </div>
                    </div>
                </div>
            <% }); %>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <div class="col-12">
                    <nav>
                        <ul class="pagination justify-content-center">
                            <% for(let i = 1; i <= totalPages; i++) { %>
                                <li class="page-item <%= currentPage === i ? "active" : "" %>">
                                    <a class="page-link" href="/donor/search?page=<%= i %><%= query.bloodGroup ? "&bloodGroup=" + query.bloodGroup : "" %><%= query.state ? "&state=" + query.state : "" %><%= query.city ? "&city=" + query.city : "" %>">
                                        <%= i %>
                                    </a>
                                </li>
                            <% } %>
                        </ul>
                    </nav>
                </div>
            <% } %>
            
        <% } else { %>
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>
                    No donors found matching your criteria. Try different search parameters.
                </div>
            </div>
        <% } %>
    </div>
</div>

<%- include("../partials/footer") %>
