<%- include("../partials/header") %>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Emergency Request Details</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h5>Patient Information</h5>
                            <p><strong>Name:</strong> <%= request.patientName %></p>
                            <p><strong>Blood Group:</strong> <span class="badge bg-danger"><%= request.bloodGroup %></span></p>
                        </div>
                        <div class="col-md-6">
                            <h5>Contact Information</h5>
                            <p><strong>Phone:</strong> <a href="tel:<%= request.phone %>"><%= request.phone %></a></p>
                            <p><strong>Hospital:</strong> <%= request.hospitalName %></p>
                        </div>
                    </div>
                    
                    <hr>
                    
                    <p><strong>Hospital Address:</strong> <%= request.hospitalAddress %></p>
                    <p><strong>City:</strong> <%= request.city %>, <%= request.state || "" %></p>
                    <p><strong>Units Required:</strong> <%= request.unitsRequired %></p>
                    <p><strong>Urgency Level:</strong> 
                        <span class="badge bg-<%= request.urgencyLevel === "critical" ? "danger" : "warning" %>">
                            <%= request.urgencyLevel.toUpperCase() %>
                        </span>
                    </p>
                    
                    <% if (request.additionalNotes) { %>
                        <p><strong>Notes:</strong> <%= request.additionalNotes %></p>
                    <% } %>
                    
                    <p><strong>Status:</strong> 
                        <span class="badge bg-<%= request.status === "pending" ? "warning" : request.status === "fulfilled" ? "success" : "secondary" %>">
                            <%= request.status.toUpperCase() %>
                        </span>
                    </p>
                </div>
                <div class="card-footer text-center">
                    <a href="tel:<%= request.phone %>" class="btn btn-danger btn-lg">
                        <i class="fas fa-phone me-2"></i>Call Now: <%= request.phone %>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("../partials/footer") %>
