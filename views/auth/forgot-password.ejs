<%- include("../partials/header") %>

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="fas fa-lock fa-3x text-danger mb-3"></i>
                        <h2>Forgot Password</h2>
                        <p class="text-muted">Enter your email to reset password</p>
                    </div>
                    
                    <form action="/auth/forgot-password" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" name="email" required placeholder="Enter your registered email">
                        </div>
                        
                        <button type="submit" class="btn btn-danger w-100 mb-3">
                            <i class="fas fa-paper-plane me-2"></i>Send Reset Link
                        </button>
                        
                        <div class="text-center">
                            <a href="/auth/login" class="text-danger">Back to Login</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("../partials/footer") %>
